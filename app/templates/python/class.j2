{% set needs_abc =
    has_abstract
    or implements
%}
{% if needs_abc %}
from abc import ABC, abstractmethod


{% endif %}
class {{ class_.name }}(
    {%- set parents = [] -%}
    {%- if extends -%}
        {%- set _ = parents.append(extends.name) -%}
    {%- endif -%}
    {%- for interface in implements -%}
        {%- set _ = parents.append(interface.name) -%}
    {%- endfor -%}
    {%- if needs_abc and not parents -%}
        {%- set _ = parents.append('ABC') -%}
    {%- endif -%}
    {{ parents | join(', ') }}
):
{% if class_.attributes %}
    {% for attribute in class_.attributes %}
    {{ map_modifier(attribute.access_modifier, attribute.name) }}: {{ attribute.type }}{% if attribute.default_value %} = {{ attribute.default_value }}{% else %} = None {% endif %}
    {% endfor %}
{% endif %}

    {% for method in class_.methods %}
    {% if method.is_abstract %}
    @abstractmethod
    {% endif %}
    def {{ method.name }}(self
        {%- for arg in method.arguments -%}
            , {{ arg.name }}: {{ arg.type }}
        {%- endfor -%}
    ) -> {{ method.return_type }}:
        pass
    {% endfor %}
    {% if not class_.attributes and not class_.methods %}
    pass
    {% endif %}
