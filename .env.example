DB_DRIVER=postgresql+asyncpg
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=postgres

AUTH_JWT_PRIVATE_KEY=your_secret_key_here
AUTH_JWT_ALGORITHM=HS256
AUTH_JWT_ACCESS_TOKEN_EXPIRE_SECONDS=3600
AUTH_JWT_REFRESH_TOKEN_EXPIRE_SECONDS=604800

RBAC_ADMIN_EMAIL=admin@example.com
RBAC_ADMIN_PASSWORD=admin123456
